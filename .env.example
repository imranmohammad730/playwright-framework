# Copy this file to .env and fill in real values
# Never commit .env to source control

# Which environment to target: dev | staging | production
TEST_ENV=dev

# Base URLs per environment
DEV_BASE_URL=https://dev.yourapp.com
STAGING_BASE_URL=https://staging.yourapp.com
PRODUCTION_BASE_URL=https://yourapp.com

# API keys per environment (optional, only if your app needs auth headers)
DEV_API_KEY=
STAGING_API_KEY=
PRODUCTION_API_KEY=

# Test user credentials for the authenticated fixture
TEST_USER_EMAIL=qa-test@yourapp.com
TEST_USER_PASSWORD=

# Slack webhook for failure notifications (optional)
SLACK_WEBHOOK_URL=
